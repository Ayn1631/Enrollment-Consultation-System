# 应用名称，仅用于服务标识、日志与文档展示。
APP_NAME=admissions-gateway

# 通用对话模型接口地址。
# 当 LLM_API_URL / EMBEDDING_API_URL / RERANK_API_URL 未单独配置时，可作为默认回退地址。
API_URL=https://www.right.codes/codex/v1/chat/completions

# 通用 API 密钥。
# 当 LLM_API_KEY / EMBEDDING_API_KEY / RERANK_API_KEY 未单独配置时，可作为默认回退密钥。
API_KEY=replace-with-your-key

# 对话生成与查询改写专用模型接口地址。
# 留空时回退到 API_URL。
LLM_API_URL=

# 对话生成与查询改写专用密钥。
# 留空时回退到 API_KEY。
LLM_API_KEY=

# 管理接口鉴权令牌，用于后台管理或受保护接口。
ADMIN_API_TOKEN=

# Agent 编排栈类型，当前默认使用 langgraph。
AGENT_STACK=langgraph

# 外部 HTTP 请求超时时间，单位秒。
REQUEST_TIMEOUT_SECONDS=6.0

# SSE 或流式输出时每块默认切片大小。
STREAM_CHUNK_SIZE=24

# 简单问题默认使用的轻量生成模型。
GENERATION_LIGHT_MODEL=gpt-4o-mini

# 复杂问题默认使用的主生成模型。
GENERATION_MAIN_MODEL=gpt-4.1

# 是否开启生成结果缓存，减少重复请求成本。
GENERATION_CACHE_ENABLED=true

# 生成缓存的有效期，单位秒。
GENERATION_CACHE_TTL_SECONDS=300

# 允许跨域访问后端的前端来源，多个地址用逗号分隔。
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# 嵌入模型接口地址。
# 留空时会基于 LLM_API_URL 或 API_URL 自动推导 /embeddings。
EMBEDDING_API_URL=

# 嵌入模型专用密钥。
# 留空时回退到 LLM_API_KEY 或 API_KEY。
EMBEDDING_API_KEY=

# 嵌入模型名称，用于向量化文档和查询。
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 嵌入批量请求大小，数值越大吞吐更高，但单次请求更重。
EMBEDDING_BATCH_SIZE=16

# 重排模型接口地址。
# 留空时会基于 LLM_API_URL 或 API_URL 自动推导 /rerank。
RERANK_API_URL=

# 重排模型专用密钥。
# 留空时回退到 LLM_API_KEY 或 API_KEY。
RERANK_API_KEY=

# 重排模型名称，用于对召回结果重新排序。
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# FAISS 向量索引的本地存储目录。
RAG_FAISS_DIR=backend/data/faiss

# 文档切块大小，影响召回粒度与上下文完整性。
RAG_CHUNK_SIZE=500

# 文档切块重叠长度，避免跨块信息断裂。
RAG_CHUNK_OVERLAP=80

# 初次召回候选数量。
RAG_RETRIEVE_TOP_N=40

# 最终送入生成阶段的文档数量上限。
RAG_FINAL_TOP_K=8

# 首轮召回质量不够时的重试召回数量。
RAG_RETRY_TOP_N=64

# 引用校验要求的最少来源数。
RAG_CITATION_MIN_SOURCES=2

# 引用校验要求的首条文档最低分数。
RAG_CITATION_MIN_TOP1_SCORE=0.18

# 检索质量门槛，过低会触发降级或重试。
RAG_QUALITY_MIN_COVERAGE=0.25

# RAG 图工作流单节点超时时间，单位毫秒。
RAG_NODE_TIMEOUT_MS=1200

# Neo4j 图谱地址；留空表示关闭图谱增强。
NEO4J_URI=

# Neo4j 用户名。
NEO4J_USER=

# Neo4j 密码。
NEO4J_PASSWORD=

# Neo4j 数据库名称。
NEO4J_DATABASE=neo4j

# LangChain4j 技能服务地址；留空表示不启用桥接。
LANGCHAIN4J_SERVICE_URL=

# LangChain4j 技能服务超时时间，单位秒。
LANGCHAIN4J_TIMEOUT_SECONDS=1.5

# 是否启用本地 mock 生成。
# true 时会关闭真实模型调用，适合离线开发；false 时才会调用真实 LLM / Embedding / Rerank。
USE_MOCK_GENERATION=true

# 服务调用模式。
# local 表示单体本地调用；http 表示通过微服务地址调用。
SERVICE_CALL_MODE=local

# RAG 微服务地址，仅在 SERVICE_CALL_MODE=http 时使用。
RAG_AGENT_SERVICE_URL=http://rag-agent-service:8001

# Memory 微服务地址，仅在 SERVICE_CALL_MODE=http 时使用。
MEMORY_SERVICE_URL=http://memory-service:8003

# Skill 微服务地址，仅在 SERVICE_CALL_MODE=http 时使用。
SKILL_SERVICE_URL=http://skill-service:8004

# Generation 微服务地址，仅在 SERVICE_CALL_MODE=http 时使用。
GENERATION_SERVICE_URL=http://generation-service:8005

# 观测服务地址，可用于监控与运维扩展。
OBSERVABILITY_SERVICE_URL=http://observability-service:8006

# RAG 微服务超时时间，单位秒。
RAG_AGENT_SERVICE_TIMEOUT_SECONDS=2.5

# Memory 微服务超时时间，单位秒。
MEMORY_SERVICE_TIMEOUT_SECONDS=0.8

# Skill 微服务超时时间，单位秒。
SKILL_SERVICE_TIMEOUT_SECONDS=1.0

# 已保存技能调用的超时时间，单位秒。
SAVED_SKILL_SERVICE_TIMEOUT_SECONDS=1.0

# 引用校验服务超时时间，单位秒。
CITATION_GUARD_TIMEOUT_SECONDS=0.4

# Generation 微服务超时时间，单位秒。
GENERATION_SERVICE_TIMEOUT_SECONDS=7.0

# 发布门禁最低通过率。
GATE_MIN_PASS_RATE=0.8

# 发布门禁允许的最大 P95 延迟，单位毫秒。
GATE_MAX_P95_MS=1500

# 发布门禁允许的最大失败样本数。
GATE_MAX_FAILED_ROWS=2

# ANN 调参评估时默认 top_k。
ANN_TUNE_TOP_K=5

# ANN 调参时最多评估的样本数。
ANN_TUNE_MAX_CASES=24

# HNSW 的 M 参数候选列表，多个值用逗号分隔。
ANN_TUNE_M_VALUES=16,32

# HNSW 的 ef_construction 候选列表。
ANN_TUNE_EF_CONSTRUCTION_VALUES=64,128

# HNSW 的 ef_search 候选列表。
ANN_TUNE_EF_SEARCH_VALUES=32,64,128
